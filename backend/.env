# Database Configuration
DATABASE_URL=postgresql://postgres:Admin%4012@localhost:5432/ztnas_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=Admin@12
DB_NAME=ztnas_db

# JWT Configuration
SECRET_KEY=ztnas-super-secret-key-min-32-chars-change-in-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App Configuration
APP_NAME=ZTNAS
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5500", "http://localhost:8000", "http://127.0.0.1:3000", "http://127.0.0.1:5500", "http://127.0.0.1:8000"]

# SMTP Configuration (for email OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Twilio Configuration (for SMS OTP)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Security
PASSWORD_MIN_LENGTH=8
SESSION_TIMEOUT_MINUTES=60
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Feature Flags
MFA_REQUIRED=True
DEVICE_TRUST_REQUIRED=True
ANOMALY_DETECTION_ENABLED=True
